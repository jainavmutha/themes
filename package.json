{
  "name": "curtain-quotation-app",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "start": "concurrently -k \"vite\" \"wait-on tcp:3002 && cross-env VITE_DEV_SERVER_URL=http://localhost:3002 electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.themes.curtainquotation",
    "productName": "Curtain Quotation App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.4.21",
    "wait-on": "^9.0.1"
  },
  "dependencies": {
    "jspdf": "^2.5.1",
    "lucide-react": "^0.441.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
